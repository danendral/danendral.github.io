---
import { experiences } from '../data/experience';
---

<section id="experience" class="py-24 px-6">
  <div class="max-w-[720px] mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold mb-12">Experience</h2>
    <div class="relative border-l-2 border-border pl-8 space-y-12">
      {experiences.map((exp) => (
        <div class="relative">
          <div class="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-accent animate-pulse-dot" />
          <p class="text-text-muted text-sm font-mono mb-1">{exp.period}</p>
          <h3 class="text-xl font-heading">
            {exp.company} <span class="text-text-secondary">— {exp.role}</span>
          </h3>
          {exp.description.length > 0 && (
            <ul class="mt-3 space-y-2">
              {exp.description.map((item) => (
                <li class="text-text-secondary text-sm leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-2 before:w-1.5 before:h-1.5 before:bg-text-muted before:rounded-full">
                  {item}
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
