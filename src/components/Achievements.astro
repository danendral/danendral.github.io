const starSvg = `<svg viewBox="0 0 20 20" fill="currentColor" class="w-[10px] h-[10px]"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>`;
---

<section id="achievements" class="py-24 px-6 section-tint">
  <div class="max-w-[720px] mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold mb-12">Achievements</h2>
    <ul class="space-y-4">
      {achievements.map((a) => (
        <li class="flex items-start gap-3 text-sm text-text-secondary">
          <span class="mt-1.5 w-2 h-2 rounded-full shrink-0 bg-accent/60" />
          {a.title}
        </li>
      ))}
    </ul>

    <div class="mt-12">
      <h3 class="font-heading text-xl font-bold mb-4 text-text-primary">Coding Profiles</h3>
      <a href="https://www.hackerrank.com/profile/dlohanata" target="_blank" rel="noopener noreferrer" class="group inline-block p-5 rounded-2xl border border-border-color bg-bg-secondary hover:border-[#F3C242]/50 transition-all duration-300 hover:shadow-lg">
        <div class="flex items-center gap-3 mb-5">
          <svg role="img" viewBox="0 0 24 24" class="w-6 h-6 fill-text-primary group-hover:fill-[#F3C242] transition-colors duration-300" xmlns="http://www.w3.org/2000/svg"><title>HackerRank</title><path d="M11.988 0l-5.63 3.25v6.5l5.63 3.25 5.63-3.25v-6.5zm0 11.375L7.483 8.775v-5.2l4.505-2.6 4.505 2.6v5.2zM7.483 16.575v-6.5l2.815 1.625v4.875zm11.26-6.5v6.5l-2.815-1.625v-4.875zM11.988 24l5.63-3.25v-6.5l-5.63 3.25-5.63-3.25v6.5l2.815 1.625v-4.875l2.815 1.625zm-2.815-13.65l2.815 1.625 2.815-1.625-2.815-1.625z"/></svg>
          <span class="font-bold text-base text-text-primary group-hover:text-[#F3C242] transition-colors">HackerRank: @dlohanata</span>
        </div>
        
        <div class="flex flex-wrap items-center gap-3">
          {hackerrankBadges.map(badge => (
            <div class="relative w-[90px] h-[100px] flex flex-col items-center justify-center bg-[#F3C242] text-[#242D36] transition-transform duration-300 group-hover:scale-105" style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); padding: 10px 8px;">
              <div class="flex-grow flex items-end">
                <div set:html={badge.icon}></div>
              </div>
              <div class="font-bold text-[9px] text-center leading-[1.1] mt-1 mb-1.5 h-[22px] flex items-center justify-center shrink-0" set:html={badge.title}></div>
              <div class="flex gap-[1px] mb-1 shrink-0">
                {Array(5).fill(0).map(() => (
                  <div set:html={starSvg}></div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </a>
    </div>
  </div>
</section>
