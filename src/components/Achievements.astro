---
import { achievements } from '../data/achievements';
---

<section id="achievements" class="py-24 px-6 section-tint">
  <div class="max-w-[720px] mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold mb-12">Achievements</h2>
    <ul class="space-y-4">
      {achievements.map((a) => (
        <li class="flex items-start gap-3 text-sm text-text-secondary">
          <span class="mt-1.5 w-2 h-2 rounded-full shrink-0 bg-accent/60" />
          {a.title}
        </li>
      ))}
    </ul>

    <div class="mt-16">
      <h3 class="font-heading text-2xl font-bold mb-6 text-text-primary">Coding Profiles</h3>
      <a href="https://www.hackerrank.com/profile/danendral" target="_blank" rel="noopener noreferrer" class="group flex flex-col sm:flex-row items-center sm:items-start gap-6 p-6 rounded-2xl border border-border-color bg-bg-secondary hover:border-[#00EA64]/50 transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
        <div class="flex flex-col items-center shrink-0">
          <svg role="img" viewBox="0 0 24 24" class="w-14 h-14 fill-text-primary group-hover:fill-[#00EA64] transition-colors duration-300" xmlns="http://www.w3.org/2000/svg"><title>HackerRank</title><path d="M11.988 0l-5.63 3.25v6.5l5.63 3.25 5.63-3.25v-6.5zm0 11.375L7.483 8.775v-5.2l4.505-2.6 4.505 2.6v5.2zM7.483 16.575v-6.5l2.815 1.625v4.875zm11.26-6.5v6.5l-2.815-1.625v-4.875zM11.988 24l5.63-3.25v-6.5l-5.63 3.25-5.63-3.25v6.5l2.815 1.625v-4.875l2.815 1.625zm-2.815-13.65l2.815 1.625 2.815-1.625-2.815-1.625z"/></svg>
        </div>
        <div class="flex-1 text-center sm:text-left">
          <h4 class="font-bold text-xl text-text-primary mb-1 group-hover:text-[#00EA64] transition-colors">HackerRank</h4>
          <p class="text-sm text-text-secondary mb-4">4× 5-Star Gold Badges</p>
          <div class="flex flex-wrap justify-center sm:justify-start gap-2">
            <span class="px-3 py-1 rounded-full bg-[#00EA64]/10 text-[#00EA64] text-xs font-semibold border border-[#00EA64]/20 group-hover:bg-[#00EA64]/20 transition-colors">Python</span>
            <span class="px-3 py-1 rounded-full bg-[#00EA64]/10 text-[#00EA64] text-xs font-semibold border border-[#00EA64]/20 group-hover:bg-[#00EA64]/20 transition-colors">Problem Solving</span>
            <span class="px-3 py-1 rounded-full bg-[#00EA64]/10 text-[#00EA64] text-xs font-semibold border border-[#00EA64]/20 group-hover:bg-[#00EA64]/20 transition-colors">SQL</span>
            <span class="px-3 py-1 rounded-full bg-[#00EA64]/10 text-[#00EA64] text-xs font-semibold border border-[#00EA64]/20 group-hover:bg-[#00EA64]/20 transition-colors">10 Days of Statistics</span>
          </div>
        </div>
      </a>
    </div>
  </div>
</section>
