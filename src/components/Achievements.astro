---
import { achievements } from '../data/achievements';

const hackerrankBadges = [
  {
    title: 'Problem<br>Solving',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 mb-[2px]"><path d="M21 16.5c0 .38-.21.71-.53.88l-7.9 4.44c-.16.12-.36.18-.57.18-.21 0-.41-.06-.57-.18l-7.9-4.44A.991.991 0 013 16.5v-9c0-.38.21-.71.53-.88l7.9-4.44c.16-.12.36-.18.57-.18.21 0 .41.06.57.18l7.9 4.44c.32.17.53.5.53.88v9zM12 2.24L4.84 6.26l6.63 3.73c.16.09.35.14.53.14.18 0 .37-.05.53-.14l6.63-3.73L12 2.24zM4.5 15.65l6.5 3.65v-7.39L4.5 8.26v7.39zm15 0v-7.39l-6.5 3.65v7.39l6.5-3.65z"/></svg>`,
  },
  {
    title: 'Python',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 mb-[2px]"><path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06-.01h8.16l.21-.01.26-.04.3-.07.33-.1.35-.14.35-.19.33-.25.3-.31.26-.38.21-.46.13-.55.05-.63V.35l-.02-.2-.04-.26-.1-.3-.16-.33-.25-.34-.34-.34-.45-.32-.59-.3-.73-.26-.9-.2-1.06-.13-1.24-.04-1.42.06-1.58.17-1.72.3-1.85.45-1.95.6-2.04.77-2.12.96-2.18 1.16zm-5.48 1.6c.39 0 .7.31.7.7s-.31.7-.7.7-.7-.31-.7-.7.31-.7.7-.7zm14.48 9.38l.21.03.28.07.32.12.35.18.36.26.36.36.35.46.32.59.28.73.21.88.14 1.05.05 1.23-.06 1.22-.16 1.04-.24.87-.32.71-.36.57-.4.44-.42.33-.42.24-.4.16-.36.1-.32.05-.24.01h-.16l-.06.01H15.6l-.21.01-.26.04-.3.07-.33.1-.35.14-.35.19-.33.25-.3.31-.26.38-.21.46-.13.55-.05.63v8.16l.02.2.04.26.1.3.16.33.25.34.34.34.45.32.59.3.73.26.9.2 1.06.13 1.24.04 1.42-.06 1.58-.17 1.72-.3 1.85-.45 1.95-.6 2.04-.77 2.12-.96 2.18-1.16v-8.31l-.05-.63-.13-.55-.21-.46-.26-.38-.3-.31-.33-.25-.35-.19-.35-.14-.33-.1-.3-.07-.26-.04-.21-.02h-6.49l.69-.05.59-.14.5-.22.41-.27.33-.32.27-.35.2-.36.15-.37.1-.35.07-.32.04-.27.02-.21v-3.06h3.69zM15.25 21.52c.39 0 .7.31.7.7s-.31.7-.7.7-.7-.31-.7-.7.31-.7.7-.7z"/></svg>`,
  },
  {
    title: 'Days of<br>Statistics',
    icon: `<span class="text-[20px] font-bold leading-none block mb-[2px] tracking-tighter">10</span>`,
  },
  {
    title: 'Sql',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 mb-[2px]"><path d="M12 2C7.58 2 4 3.79 4 6s3.58 4 8 4 8-1.79 8-4-3.58-4-8-4zm0 6c-3.1 0-5.74-1.21-6.9-3 1.16-1.79 3.8-3 6.9-3s5.74 1.21 6.9 3c-1.16 1.79-3.8 3-6.9 3z"/><path d="M4 9v2c0 2.21 3.58 4 8 4s8-1.79 8-4V9c0 2.21-3.58 4-8 4s-8-1.79-8-4"/><path d="M4 14v2c0 2.21 3.58 4 8 4s8-1.79 8-4v-2c0 2.21-3.58 4-8 4s-8-1.79-8-4"/></svg>`,
  }
