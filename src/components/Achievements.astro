---
import { achievements } from '../data/achievements';
---

<section id="achievements" class="py-24 px-6 section-tint">
  <div class="max-w-[720px] mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold mb-12">Achievements</h2>
    <ul class="space-y-4">
      {achievements.map((a) => (
        <li class="flex items-start gap-3 text-sm text-text-secondary">
          <span class="mt-1.5 w-2 h-2 rounded-full shrink-0 bg-accent/60" />
          {a.title}
        </li>
      ))}
    </ul>
  </div>
</section>
