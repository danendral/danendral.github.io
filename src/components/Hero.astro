<section class="min-h-screen flex items-center justify-center px-6 pt-20 relative overflow-hidden">
  <!-- Subtle background decoration -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #5BA4CF 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="max-w-[1080px] w-full flex flex-col md:flex-row items-center gap-12 md:gap-16 relative z-10">
    <!-- Profile Image -->
    <div class="shrink-0 animate-fade-in-up">
      <div class="w-48 h-48 md:w-64 md:h-64 rounded-full overflow-hidden profile-glow ring-2 ring-accent/20">
        <img src="/profile_image.png" alt="Danendra Lohanata" class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Text Content -->
    <div class="text-center md:text-left">
      <p class="text-text-muted text-sm font-mono mb-3 tracking-widest uppercase animate-fade-in-up">Data, AI, and Analytics</p>
      <h1 class="font-heading text-5xl md:text-7xl font-bold mb-4 animate-fade-in-up tracking-tight" style="animation-delay: 100ms;">
        Danendra<br/>Lohanata
