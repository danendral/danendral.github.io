---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <section class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <h1 class="font-heading text-6xl mb-4">404</h1>
      <p class="text-text-secondary mb-8">This page doesn't exist.</p>
      <a href="/" class="text-accent hover:text-accent-dim transition-colors">Go home</a>
    </div>
  </section>
</BaseLayout>
