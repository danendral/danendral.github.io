---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.filter(post => !post.data.draft).map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const date = new Date(post.data.date);
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${post.data.title} — Danendra Lohanata`}>
  <article class="pt-32 pb-24 px-6">
    <div class="max-w-[720px] mx-auto">
      <p class="text-text-muted text-sm font-mono mb-4">{formattedDate}</p>
      <h1 class="font-heading text-4xl md:text-5xl mb-6 leading-tight">{post.data.title}</h1>

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="flex gap-2 mb-10 flex-wrap">
          {post.data.tags.map(tag => (
            <span class="text-xs font-mono text-accent bg-accent/10 px-2.5 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      )}

      <div class="blog-content">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  .blog-content {
    color: var(--color-text-secondary);
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .blog-content h2 {
    font-family: var(--font-heading);
    color: var(--color-text-primary);
    font-size: 1.875rem;
    font-weight: 600;
    margin-top: 4rem;
    margin-bottom: 1.25rem;
    line-height: 1.3;
    padding-top: 1rem;
  }

  .blog-content h3 {
    font-family: var(--font-heading);
    color: var(--color-text-primary);
    font-size: 1.35rem;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .blog-content p {
    margin-bottom: 1.5rem;
    line-height: 1.85;
  }

  .blog-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .blog-content ul li {
    list-style-type: disc;
    margin-bottom: 0.6rem;
    line-height: 1.7;
    padding-left: 0.25rem;
  }

  .blog-content ul li::marker {
    color: var(--color-accent);
  }

  .blog-content ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .blog-content ol li {
    margin-bottom: 0.6rem;
    line-height: 1.7;
    padding-left: 0.25rem;
  }

  .blog-content ol li::marker {
    color: var(--color-accent);
    font-weight: 600;
  }

  .blog-content strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .blog-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }

  .blog-content a:hover {
    color: var(--color-accent-dim);
  }

  .blog-content blockquote {
    border-left: 3px solid var(--color-accent);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    background: rgba(91, 164, 207, 0.04);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .blog-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 3rem 0;
  }

  .blog-content table {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .blog-content table thead {
    background: var(--color-bg-elevated);
  }

  .blog-content table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-weight: 600;
    color: var(--color-text-primary);
    border-bottom: 2px solid var(--color-border);
    font-family: var(--font-heading);
  }

  .blog-content table td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-secondary);
  }

  .blog-content table tbody tr:hover {
    background: rgba(91, 164, 207, 0.03);
  }

  .blog-content img {
    width: 100%;
    border-radius: 12px;
    margin: 2rem 0;
    border: 1px solid var(--color-border);
  }

  .blog-content code:not(pre code) {
    background: var(--color-bg-elevated);
    color: var(--color-accent);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.88em;
  }

  .blog-content pre {
    position: relative;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    margin: 1.5rem 0;
    overflow: hidden;
  }

  .blog-content pre code {
    display: block;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .blog-content pre .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    font-size: 0.75rem;
    cursor: pointer;
    font-family: var(--font-mono);
    transition: all 0.2s;
    opacity: 0;
  }

  .blog-content pre:hover .copy-btn {
    opacity: 1;
  }

  .blog-content pre .copy-btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .blog-content pre .copy-btn.copied {
    background: #22c55e;
    color: white;
    border-color: #22c55e;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.blog-content pre').forEach(pre => {
      const code = pre.querySelector('code');
      if (!code) return;

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'Copy';

      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(code.textContent);
          btn.textContent = 'Copied!';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = 'Copy';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = 'Failed';
          setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
        }
      });

      pre.appendChild(btn);
    });
  });
</script>
