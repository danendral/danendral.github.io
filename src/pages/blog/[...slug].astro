---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Danendra Lohanata`}>
  <article class="pt-32 pb-24 px-6">
    <div class="max-w-[720px] mx-auto">
      <p class="text-text-muted text-sm font-mono mb-4">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <h1 class="font-heading text-4xl md:text-5xl mb-8">{post.data.title}</h1>
      <div class="prose prose-invert max-w-none text-text-secondary [&_h2]:font-heading [&_h2]:text-text-primary [&_a]:text-accent">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
